{
  "name": "blinkfolio-backend",
  "version": "0.1.0",
  "description": "Blinkfolio backend API",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --watch --experimental-transform-types --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src smoke-tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --project unit",
    "test:smoke": "vitest run --project smoke",
    "migrate": "node-pg-migrate --migrations-dir migrations --envPath .env",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language ts --envPath .env",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations --envPath .env",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --envPath .env"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.7"
  }
}
